{
  "expo": {
    "name": "Kafe Eman",
    "slug": "kafeeman",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kafeeman",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios"
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#608070"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devmalitos.kafeeman",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "tel",
          "telprompt"
        ],
        "NSLocationWhenInUseUsageDescription": "Show your location on the live delivery map."
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#608070",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "ios": {
            "backgroundColor": "#608070"
          }
        }
      ],
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-font",
      "@clerk/expo",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e7337a07-750d-4b0d-96a5-d78bcc7977dc"
      },
      "router": {}
    },
    "owner": "devmalitos"
  }
}
