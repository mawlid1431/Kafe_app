# Copy to .env.local and fill in values (never commit .env.local)

# Expo
EXPO_USE_BUN=1
EAS_PROJECT_ID=

# Clerk — dashboard.clerk.com → API Keys (Native application)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Convex — from dashboard.convex.dev or `npx convex dev`
CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL=

# Convex dashboard only (not .env.local) — JWT template name must be "convex":
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://YOUR-INSTANCE.clerk.accounts.dev

# Start both mobile app + admin: bun run dev
#   Mobile  → scan QR in terminal (Expo Go)
#   Admin   → http://localhost:5173/login
# Default login after seed: admin / admin123
