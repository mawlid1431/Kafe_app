{
  "name": "kafeeman",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "author": "Mawlid Mohamud (Malitos) <malitmohamud@gmail.com> (https://github.com/mawlid1431)",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "expo-router/entry",
  "scripts": {
    "preinstall": "only-allow bun",
    "start": "bun run dev",
    "dev": "bun scripts/dev.mjs dev",
    "app": "bun scripts/dev.mjs app",
    "admin": "bun scripts/dev.mjs admin",
    "expo:dev": "bunx expo start --lan",
    "dev:clear": "bunx expo start --lan --clear",
    "dev:fix": "bun install && bunx expo start --lan --clear",
    "start:tunnel": "bunx expo start --tunnel",
    "ios": "bunx expo run:ios",
    "build:ios": "bunx eas build --platform ios --profile preview",
    "build:ios:prod": "bunx eas build --platform ios --profile production",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx expo lint",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy",
    "convex:seed": "bunx convex run seed:runDev",
    "admin:build": "cd Admin && bun run build"
  },
  "dependencies": {
    "@clerk/expo": "^3.6.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "convex": "^1.42.0",
    "expo": "^54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.17",
    "only-allow": "^1.2.2",
    "typescript": "~5.9.3"
  }
}
